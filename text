    btn.textContent='✓ Subscribed!'; btn.style.background='#5c3d2e';
    inp.value=''; setTimeout(()=>{ btn.textContent='Subscribe'; btn.style.background=''; },3000);
  } else {
    inp.style.borderColor='#c8622a'; inp.focus();
    setTimeout(()=>{ inp.style.borderColor=''; },1500);
  }
});
</script>
