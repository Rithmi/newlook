  <div class="pre-corner tl"></div>
  <div class="pre-corner tr"></div>
  <div class="pre-corner bl"></div>
  <div class="pre-corner br"></div>

  <div class="pre-center" id="preCenter">
    <!-- Animated logo mark -->
    <div class="pre-logo-mark">
      <div class="pre-ring"></div>
      <div class="pre-ring"></div>
      <div class="pre-ring"></div>
      <div class="pre-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <rect x="2" y="10" width="20" height="4" rx="2"/>
          <rect x="4" y="6" width="16" height="4" rx="2"/>
          <rect x="5" y="14" width="2" height="5" rx="1"/>
          <rect x="17" y="14" width="2" height="5" rx="1"/>
        </svg>
      </div>
