  </div>
</div>

<!-- ═══ PAGE CONTENT ═══ -->
<div id="page-content">

<!-- NAVBAR -->
<nav id="navbar">
  <div class="nav-inner">
    <a href="#" class="nav-logo">
      <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" style="width:26px;height:26px;">
